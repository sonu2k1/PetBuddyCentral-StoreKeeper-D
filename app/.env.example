# Database — PostgreSQL (Neon / Supabase / Railway) connection string
# For Vercel deployment, use a hosted PostgreSQL (SQLite does NOT work on Vercel)
DATABASE_URL="postgresql://username:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# NextAuth.js — Generate a secure secret: openssl rand -base64 32
AUTH_SECRET="your-secret-key-here"

# Application URL — Set to your Vercel URL in production (e.g. https://your-app.vercel.app)
# On Vercel, this is auto-detected if not set, but it's recommended to set it explicitly
AUTH_URL="http://localhost:3000"

# Trust the host header (required for reverse proxies like Vercel)
AUTH_TRUST_HOST="true"

